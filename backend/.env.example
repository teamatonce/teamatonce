# =====================================================
# TEAMATONCE BACKEND CONFIGURATION
# =====================================================
# Copy this file to .env and update with your values
# =====================================================

# Application
PORT=3001
NODE_ENV=development
API_PREFIX=api/v1

# URLs
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:3001
CORS_ORIGIN=http://localhost:5173,http://localhost:3000

# =====================================================
# DATABASE (PostgreSQL)
# =====================================================
# These defaults match docker-compose.yml.
# If you use your own PostgreSQL, update accordingly.

DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=teamatonce_dev
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres

# =====================================================
# REDIS
# =====================================================

REDIS_HOST=localhost
REDIS_PORT=6379

# =====================================================
# JWT
# =====================================================

JWT_SECRET=your_jwt_secret_min32chars_change_me
JWT_EXPIRES_IN=7d

# =====================================================
# STRIPE (Escrow & Contract Payments)
# =====================================================

STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret


# =====================================================
# OAUTH
# =====================================================

OAUTH_STATE_SECRET=your-secure-random-state-secret

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:3001/auth/social/google/callback

# GitHub OAuth
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret
GITHUB_REDIRECT_URI=http://localhost:3001/auth/social/github/callback

# =====================================================
# FIREBASE (Push Notifications)
# =====================================================

FIREBASE_SERVICE_ACCOUNT=./firebase-adminsdk.json

# =====================================================
# DATA ENGINE / CRAWLER
# =====================================================

GITHUB_TOKEN=ghp_your_github_personal_access_token
CRAWLER_DEFAULT_DELAY_MS=1000

# =====================================================
# OPENAI
# =====================================================

OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=gpt-4o-mini

# =====================================================
# QDRANT
# =====================================================

QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_API_KEY=your_qdrant_api_key

# =====================================================
# EMAIL
# =====================================================
# Pick a provider. See backend/docs/providers/email.md for the full
# comparison and per-provider env vars.
#
# Valid values: smtp | resend | sendgrid | postmark | ses | mailgun | none

EMAIL_PROVIDER=smtp
EMAIL_FROM=Team@Once <noreply@teamatonce.com>
EMAIL_REPLY_TO=

# --- SMTP (default, works with Gmail/Mailtrap/Postfix/etc) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=

# --- Resend (https://resend.com) ---
RESEND_API_KEY=

# --- SendGrid (https://sendgrid.com) ---
SENDGRID_API_KEY=

# --- Postmark (https://postmarkapp.com) ---
POSTMARK_SERVER_TOKEN=

# --- AWS SES (optional dep @aws-sdk/client-ses) ---
SES_REGION=us-east-1
SES_ACCESS_KEY_ID=
SES_SECRET_ACCESS_KEY=

# --- Mailgun (https://www.mailgun.com) ---
MAILGUN_API_KEY=
MAILGUN_DOMAIN=
MAILGUN_REGION=us
