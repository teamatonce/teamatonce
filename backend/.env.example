# =====================================================
# TEAMATONCE BACKEND CONFIGURATION
# =====================================================
# Copy this file to .env and update with your values
# =====================================================

# Application
PORT=3001
NODE_ENV=development
API_PREFIX=api/v1

# URLs
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:3001
CORS_ORIGIN=http://localhost:5173,http://localhost:3000

# =====================================================
# DATABASE (PostgreSQL)
# =====================================================
# These defaults match docker-compose.yml.
# If you use your own PostgreSQL, update accordingly.

DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=teamatonce_dev
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres

# =====================================================
# REDIS
# =====================================================

REDIS_HOST=localhost
REDIS_PORT=6379

# =====================================================
# JWT
# =====================================================

JWT_SECRET=your_jwt_secret_min32chars_change_me
JWT_EXPIRES_IN=7d

# =====================================================
# STRIPE (Escrow & Contract Payments)
# =====================================================

STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret


# =====================================================
# OAUTH
# =====================================================

OAUTH_STATE_SECRET=your-secure-random-state-secret

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:3001/auth/social/google/callback

# GitHub OAuth
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret
GITHUB_REDIRECT_URI=http://localhost:3001/auth/social/github/callback

# =====================================================
# FIREBASE (Push Notifications)
# =====================================================

FIREBASE_SERVICE_ACCOUNT=./firebase-adminsdk.json

# =====================================================
# DATA ENGINE / CRAWLER
# =====================================================

GITHUB_TOKEN=ghp_your_github_personal_access_token
CRAWLER_DEFAULT_DELAY_MS=1000

# =====================================================
# OPENAI
# =====================================================

OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=gpt-4o-mini

# =====================================================
# QDRANT
# =====================================================

QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_API_KEY=your_qdrant_api_key

# =====================================================
# AUTH / SSO (pluggable)
# =====================================================
# Comma-separated list of enabled providers for this deployment.
# `local` (email + password) is always on; you don't need to list it.
# See backend/docs/providers/auth-sso.md for per-provider setup.
#
# Implemented in PR #46:
#   local, google, github, magic-link
#
# Planned follow-ups (part of issue #31):
#   gitlab, keycloak, clerk, auth0

AUTH_PROVIDERS=local

# --- Magic Link (passwordless email sign-in) ---
MAGIC_LINK_TTL_SECONDS=900
# FRONTEND_URL is already set above in the App section — used to build
# the click-through link in the email body.
