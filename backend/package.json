{
  "name": "teamatonce-backend",
  "version": "1.0.0",
  "description": "TeamAtOnce Backend - AI-Driven Development Outsourcing Platform API",
  "main": "index.js",
  "directories": {
    "test": "tests"
  },
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "migrate": "node scripts/migrate.js",
    "seed": "node scripts/seed-test-data.js seed",
    "seed:clear": "node scripts/seed-test-data.js clear",
    "seed:reset": "node scripts/seed-test-data.js reset",
    "seed:admin": "ts-node scripts/seed-admin.ts",
    "seed:instructor": "ts-node scripts/seed-instructor.ts",
    "seed:courses": "ts-node scripts/seed-courses.ts",
    "seed:all": "ts-node -r tsconfig-paths/register src/database/seeds/seed.ts",
    "seed:dev": "npm run build && node dist/database/seeds/seed.js",
    "clear:data": "ts-node -r tsconfig-paths/register src/database/scripts/clear-all-data.ts",
    "reset:db": "npm run clear:data && npm run migrate",
    "check:role": "ts-node scripts/check-user-role.ts",
    "set:admin": "ts-node scripts/set-admin-role.ts",
    "deploy:rollback": "node scripts/deploy-rollback.js",
    "deploy:scale": "node scripts/deploy-scale.js"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1028.0",
    "@aws-sdk/s3-request-presigner": "^3.1028.0",
    "@nestjs/common": "^11.1.6",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.1.6",
    "@nestjs/jwt": "^11.0.0",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.6",
    "@nestjs/platform-socket.io": "^11.1.6",
    "@nestjs/schedule": "^6.0.1",
    "@nestjs/swagger": "^11.2.0",
    "@nestjs/websockets": "^11.1.6",
    "@octokit/rest": "^22.0.1",
    "@qdrant/js-client-rest": "^1.16.2",
    "@socket.io/redis-adapter": "^8.3.0",
    "@types/multer": "^2.0.0",
    "@types/passport-jwt": "^4.0.1",
    "@types/pg": "^8.20.0",
    "@types/puppeteer": "^5.4.7",
    "@types/uuid": "^10.0.0",
    "axios": "^1.12.2",
    "bcryptjs": "^3.0.2",
    "bottleneck": "^2.19.5",
    "bullmq": "^5.73.3",
    "cheerio": "^1.2.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.2",
    "firebase-admin": "^13.6.0",
    "ioredis": "^5.9.2",
    "multer": "^2.0.2",
    "nodemailer": "^8.0.0",
    "openai": "^6.17.0",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pg": "^8.20.0",
    "puppeteer": "^24.36.1",
    "puppeteer-extra": "^3.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2",
    "redis": "^5.8.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "socket.io": "^4.8.1",
    "stripe": "^22.0.1",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.14",
    "@nestjs/schematics": "^11.0.7",
    "@nestjs/testing": "^11.1.6",
    "@types/bcryptjs": "^2.4.6",
    "@types/express": "^5.0.3",
    "@types/node": "^24.3.0",
    "@types/nodemailer": "^7.0.9",
    "@typescript-eslint/eslint-plugin": "^8.40.0",
    "@typescript-eslint/parser": "^8.40.0",
    "dotenv": "^17.2.3",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9.33.0",
    "prettier": "^3.6.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.9.2"
  }
}
